{
    "presets": [
        "@babel/preset-react",
        "@babel/preset-typescript"
    ],
    "plugins": [
        [
            "babel-plugin-react-compiler",
            {
                "target": "18"
            }
        ]
    ],
    "env": {
        "esm": {
            "presets": [
                [
                    "@babel/preset-env",
                    {
                        "targets": ">0.5%, not dead, not op_mini all, chrome 71",
                        "modules": false
                    }
                ]
            ]
        },
        "cjs": {
            "presets": [
                [
                    "@babel/preset-env",
                    {
                        "targets": { "node": 12 },
                        "modules": "commonjs"
                    }
                ]
            ]
        }
    },
    "comments": false
}
